# Supabase — copia da Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SOLO server side, MAI esporre al client.
# Usata per operazioni privilegiate (creazione inviti, promozione utenti).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL pubblico dell'app (usato nei link di invito email)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
